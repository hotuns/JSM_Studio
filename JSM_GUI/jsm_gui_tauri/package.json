{
  "name": "jsm-studio",
  "private": true,
  "version": "0.2.1",
  "description": "JSM Studio for JoyShockMapper (Tauri)",
  "author": "Evan McLean",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "build": "tauri build",
    "build:web": "tsc && vite build",
    "native:configure": "cmake -S native/console-injector -B native/console-injector/build",
    "native:build": "cmake --build native/console-injector/build --config Release",
    "build:sidecars": "powershell -ExecutionPolicy Bypass -File scripts/build-console-injector.ps1",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:admin": "powershell -ExecutionPolicy Bypass -File scripts/tauri-dev-admin.ps1",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "i18next": "^26.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "baseline-browser-mapping": "^2.9.14",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^7.2.2"
  }
}
